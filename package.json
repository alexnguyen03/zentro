{
  "name": "zentro",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "build": "powershell -ExecutionPolicy Bypass -File build_zentro.ps1",
    "build:dev": "powershell -ExecutionPolicy Bypass -File build_zentro.ps1 -Dev",
    "hooks:install": "node scripts/setup-git-hooks.mjs",
    "verify:push": "node scripts/verify-push.mjs",
    "test:backend": "go test ./... -coverprofile=coverage-backend.out",
    "test:frontend": "cmd /c \"cd frontend && npm run test\"",
    "check:backend:guardrails": "node scripts/check-be-guardrails.mjs",
    "check:backend:debt": "node scripts/be-debt-dashboard.mjs",
    "check:frontend:guardrails": "cmd /c \"cd frontend && npm run check:guardrails\"",
    "check:frontend:guardrails:test": "node scripts/tests/check-fe-guardrails-regression.mjs",
    "check:frontend:design-system": "cmd /c \"cd frontend && npm run check:design-system-contract\"",
    "check:frontend:boundaries": "node scripts/check-feature-boundaries.mjs",
    "check:frontend:debt": "cmd /c \"cd frontend && npm run check:debt\"",
    "bench:query-dx": "powershell -ExecutionPolicy Bypass -File scripts/query-dx-harness.ps1",
    "smoke": "go build ./... && go test ./... && node scripts/check-feature-boundaries.mjs && cmd /c \"cd frontend && npm run check:wails-models && npm run build && npm run test\"",
    "release": "commit-and-tag-version",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.5.0"
  }
}
